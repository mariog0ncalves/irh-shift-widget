{
  "manifest_version": 2,
  "name": "iRH+ Widget",
  "version": "1.1.0",
  "description": "Widget for iRH+ to display shifts and assiduity information",
  "permissions": ["notifications"],
  "icons": {
    "16": "icons/ico.png",
    "32": "icons/ico.png",
    "48": "icons/ico.png",
    "128": "icons/ico.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/ico.png",
      "32": "icons/ico.png",
      "48": "icons/ico.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://irh.pt/picagens/picagens_c"
      ],
      "js": ["utils.js", "shift.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://irh.pt/assiduidade/assiduidade_c"
      ],
      "js": ["utils.js", "attendance.js"],
      "run_at": "document_idle"
    }
  ],
  "applications": {
    "gecko": {
      "id": "irh-counter@acin.pt"
    }
  }
}
